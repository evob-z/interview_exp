# DeepSeek 配置
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Qwen 配置（备选/对比用）
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# 默认使用哪个 provider
DEFAULT_PROVIDER=deepseek

# 路径配置（根据实际环境修改，支持绝对路径）
INTERVIEW_REPO_PATH=/path/to/your/interview_exp
PROJECT_PATHS=/path/to/project_a,/path/to/project_b

# === 路径配置 ===
RAW_INPUT_DIR=面试原始问题
REVIEW_OUTPUT_DIR=面试复盘
RESUME_DIR=个人情况/简历
COMPANY_EXCEL_PATH=
PREP_OUTPUT_DIR=岗位预测
PREP_QUESTION_COUNT=20

# === 岗位预测 Agent（Pydantic AI）===
# Agent LLM 请求次数上限（含工具调用循环）
PREP_AGENT_MAX_ITERS=8
# Agent 失败时是否回退线性流水线（建议保留 true）
PREP_AGENT_FALLBACK=true

# === 面试反思（PydanticAI 双 Agent）===
# 反思对话最大轮次（达到后强制停止）
REFLECT_MAX_ROUNDS=8
# 覆盖度停止阈值（5 维度全部 ≥ 此值自动停止，0-100）
REFLECT_COVERAGE_THRESHOLD=70
# Notepad 草稿纸最大字符数（每轮注入 system prompt，建议 8k~20k）
NOTEPAD_MAX_CHARS=16000
# Notepad 单个 section 最大字符数（超出自动压缩，保留头尾）
NOTEPAD_MAX_SECTION_CHARS=2400

# 项目文档配置（格式：项目名:路径:文档文件1,文档文件2，多个项目用分号分隔）
# 【推荐】留空，由 projects.yaml 统一管理（单一真相源）
# 仅在需要覆盖 yaml 时显式设置
# PROJECT_CONFIGS=project_a:/path/to/project_a:README.md;project_b:/path/to/project_b:README.md

# === projects.yaml 配置文件路径（可选）===
# 默认使用 AAA_manager/projects.yaml
# 如需使用自定义配置文件，指定绝对路径
# PROJECTS_YAML_PATH=/path/to/my_projects.yaml

# === 网络搜索 ===
ENABLE_WEB_SEARCH=true
SEARCH_API_KEY=
SEARCH_API_PROVIDER=tavily

# === Git 集成 ===
GIT_ENABLED=false

# === Web 服务 ===
WEB_HOST=127.0.0.1
WEB_PORT=8000

# === HuggingFace 镜像（国内网络加速模型下载） ===
HF_ENDPOINT=https://hf-mirror.com

# === 语音输入（可选）===
ENABLE_VOICE_INPUT=false
XUNFEI_APP_ID=
XUNFEI_API_KEY=
XUNFEI_API_SECRET=
