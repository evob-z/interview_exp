# DeepSeek 配置
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Qwen 配置（备选/对比用）
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# 默认使用哪个 provider
DEFAULT_PROVIDER=deepseek

# 路径配置（根据实际环境修改，支持绝对路径）
INTERVIEW_REPO_PATH=/path/to/your/interview_exp
PROJECT_PATHS=/path/to/project_a,/path/to/project_b

# === 路径配置 ===
RAW_INPUT_DIR=面试原始问题
REVIEW_OUTPUT_DIR=面试复盘
RESUME_DIR=个人情况/简历
COMPANY_EXCEL_PATH=

# 项目文档配置（格式：项目名:路径:文档文件1,文档文件2）
# 多个项目用分号分隔
PROJECT_CONFIGS=project_a:/path/to/project_a:README.md;project_b:/path/to/project_b:README.md

# === 网络搜索 ===
ENABLE_WEB_SEARCH=true
SEARCH_API_KEY=
SEARCH_API_PROVIDER=tavily

# === Web 服务 ===
WEB_HOST=127.0.0.1
WEB_PORT=8000
