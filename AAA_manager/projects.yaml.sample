# =============================================================================
# 候选人项目元信息（唯一真相源）— 配置模板
#
# 本文件被 config.py 自动加载，派生以下运行时配置：
#   - PROJECT_ALIASES        关键词 -> category（用于检索加权）
#   - CATEGORY_FILE_MAP      category -> 题库文件名（archiver 入库依据）
#   - PROJECT_CONFIGS        项目文档配置（兜底，若 .env 中未显式设置）
#   - extract_system.md      运行时注入项目分类清单（供 LLM 抽取分类）
#
# =============================================================================
# 使用方式
# =============================================================================
# 方式一（推荐）：复制为 projects.yaml，系统默认加载
#   cp projects.yaml.sample projects.yaml
#
# 方式二：通过环境变量指定自定义路径
#   在 .env 中设置：PROJECTS_YAML_PATH=/path/to/my_projects.yaml
#
# 方式三：保留本文件作为模板，创建多份配置按需切换
#   cp projects.yaml.sample projects_dev.yaml    # 开发环境
#   cp projects.yaml.sample projects_prod.yaml   # 生产环境
#
# 注意：projects.yaml 已被 .gitignore，包含真实信息不会提交到 Git
# =============================================================================

# =============================================================================
# 字段说明
# =============================================================================
# name        必填。category 主键；对应题库文件 项目-{name}.md
# display     必填。中文展示名（README / Web 显示用）
# path        可选。项目源码或文档绝对路径（若填则自动注册到 PROJECT_CONFIGS）
# docs        可选。项目内的文档文件名列表（默认 [README.md]）
# aliases     必填。LLM 与检索识别项目的关键词；越细越准
# description 必填。一句话项目说明，会注入到抽取 prompt，供 LLM 判断分类
#
# qa_tier1    可选。QA 问答时项目知识的渐进式披露配置：
#   base_dir   项目目录下存放面试准备材料的子目录
#   files      按优先级排列的 Markdown 文件列表（越靠前优先级越高）
#              QA 系统会按需逐层加载，避免一次注入过多 token
# =============================================================================

projects:
  # ---------------------------------------------------------------------------
  # 示例项目 A：完整配置（含 qa_tier1）
  # ---------------------------------------------------------------------------
  - name: project_a
    display: 项目A中文名
    path: /absolute/path/to/project_a
    docs: [README.md, docs/architecture.md]
    aliases: [关键词1, 关键词2, 别名缩写]
    description: 一句话讲清楚项目领域 / 核心技术 / 主要成果
    qa_tier1:
      base_dir: 面试
      files:
        - 01_项目总览与个人工作.md
        - 02_系统架构与核心流程.md
        - 03_评估体系与量化指标.md
        - 04_核心技术深挖.md
        - 05_高频追问_QA.md

  # ---------------------------------------------------------------------------
  # 示例项目 B：最小配置（无 path / docs / qa_tier1）
  # ---------------------------------------------------------------------------
  - name: project_b
    display: 项目B
    aliases: [关键词A, 关键词B]
    description: 例如「合规审查 RAG，覆盖风电 / 环评等领域，Multi-HyDE + BM25 + RRF」

  # ---------------------------------------------------------------------------
  # 示例项目 C：带 qa_tier1 但无 path（纯面试准备项目）
  # ---------------------------------------------------------------------------
  - name: project_c
    display: 项目C
    aliases: [关键词X, 关键词Y, SFT, 微调]
    description: 例如「智能旅行顾问 Agent，0.6B 模型 SFT，Function Calling 多轮对话」
    qa_tier1:
      base_dir: 面试
      files:
        - 01_项目总览与核心亮点.md
        - 02_QA检索优先级与上下文控制.md
        - 03_评估体系与量化指标.md
        - 04_核心技术深挖.md
        - 05_高频追问_QA.md

# =============================================================================
# 通用题库分类（非项目类）
# =============================================================================
# 这些分类不绑定具体项目，用于存放通用技术问题（如八股文、AI 工具使用等）
# 可按需增减，新增分类后需在 问题库/ 目录下创建对应的 .md 文件
# =============================================================================

generic_categories:
  - name: AI_Coding
    description: AI 工具使用类问题（Cursor / Qoder / Skill / Rules / MCP 等）
  - name: 八股
    description: 技术原理类问题（RAG / Embedding / Rerank / BM25 / 微调 / Agent 范式 / HTTP 等）
